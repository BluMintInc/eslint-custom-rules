# Ignore everything by default
*

# Then whitelist only what should be published
!lib/**/*.js
!lib/**/*.d.ts
!lib/**/*.js.map

# Ship the machine-readable release manifest so agora can re-enable OFF rules by
# exact rule name from node_modules/@blumintinc/eslint-plugin-blumint/.
!release-manifest.json

# Ensure package.json stays in root only
lib/package.json

# Log files
*.log
jest.*
*.xml
**/tests/**
tsconfig.json
*.map
src
scripts
*.sh